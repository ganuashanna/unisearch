{
  "version": 2,
  "builds": [
    { "src": "api/*.php", "use": "@vercel/php" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/search",       "dest": "/api/search.php" },
    { "src": "/api/autocomplete", "dest": "/api/autocomplete.php" },
    { "src": "/api/student",      "dest": "/api/student.php" },
    { "src": "/api/departments",  "dest": "/api/departments.php" },
    { "src": "/api/stats",        "dest": "/api/stats.php" },
    { "src": "/api/export",       "dest": "/api/export.php" },
    { "src": "/api/upload",       "dest": "/api/upload.php" },
    { "src": "/api/login",        "dest": "/api/login.php" },
    { "src": "/api/logout",       "dest": "/api/logout.php" },
    { "src": "/admin",            "dest": "/public/admin.html" },
    { "src": "/dashboard",        "dest": "/public/dashboard.html" },
    { "src": "/assets/(.*)",      "dest": "/public/assets/$1" },
    { "src": "/(.*)",             "dest": "/public/index.html" }
  ]
}

{
  "version": 2,
  "rewrites": [
    { "source": "/api/test",         "destination": "/api/test.js" },
    { "source": "/api/search",       "destination": "/api/search.js" },
    { "source": "/api/autocomplete", "destination": "/api/autocomplete.js" },
    { "source": "/api/student",      "destination": "/api/student.js" },
    { "source": "/api/departments",  "destination": "/api/departments.js" },
    { "source": "/api/stats",        "destination": "/api/stats.js" },
    { "source": "/api/export",       "destination": "/api/export.js" },
    { "source": "/api/upload",       "destination": "/api/upload.js" },
    { "source": "/api/login",        "destination": "/api/login.js" },
    { "source": "/api/logout",       "destination": "/api/logout.js" },
    { "source": "/api/seed",         "destination": "/api/seed.js" },
    { "source": "/admin",            "destination": "/public/admin.html" },
    { "source": "/dashboard",        "destination": "/public/dashboard.html" },
    { "source": "/assets/:path*",    "destination": "/public/assets/:path*" },
    { "source": "/(.*)",             "destination": "/public/index.html" }
  ]
}

